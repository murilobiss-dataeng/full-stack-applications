{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://courtlytics.local/schemas/raw_lawyer.json",
  "title": "RawLawyerRecord",
  "description": "Expected shape for each element in raw lawyers.records before ETL.",
  "type": "object",
  "required": ["lawyer_id", "full_name"],
  "properties": {
    "lawyer_id": { "type": "string", "minLength": 1, "pattern": "^L[0-9]+$" },
    "full_name": { "type": "string", "minLength": 1 },
    "bar_state": { "type": "string", "pattern": "^[A-Z]{2}$" },
    "practice_area": { "type": "string" }
  },
  "additionalProperties": true
}
