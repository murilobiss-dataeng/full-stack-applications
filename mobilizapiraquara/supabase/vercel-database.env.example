# Cole na Vercel (Settings → Environment Variables)
# Substitua [YOUR-PASSWORD] pela senha em Supabase → Settings → Database
#
# Runtime (Prisma na Vercel) — Transaction pooler, porta 6543:
DATABASE_URL=postgresql://postgres.rlnwmayegemuioiywpli:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# Migrations / session — porta 5432 no mesmo host:
DIRECT_URL=postgresql://postgres.rlnwmayegemuioiywpli:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres
#
# Opcional: se só tiver URL curta db.xxx:5432, defina também:
# SUPABASE_REGION=us-east-1
# SUPABASE_POOLER_PREFIX=aws-1
#
# Login redação (tabela User): manco@mobilizapiraquara.com.br / manco
