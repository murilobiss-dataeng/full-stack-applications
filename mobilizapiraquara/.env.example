# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database — Supabase: Settings → Database → Connection string (URI, modo Transaction)
# Schema SQL: mobilizapiraquara/supabase/schema.sql + seed.sql
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Auth publicação (/publique) — configure na Vercel
AUTH_SECRET="gere-um-secret-aleatorio-com-openssl-rand-base64-32"
USERNAME="redacao"
PASSWORD="altere-esta-senha"

# Seed local (opcional; login em produção usa USERNAME/PASSWORD acima)
ADMIN_EMAIL="admin@mobilizapiraquara.com.br"
ADMIN_PASSWORD="altere-esta-senha"

# OpenAI (formatação automática de notícias)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Cloudinary (upload de imagens)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
