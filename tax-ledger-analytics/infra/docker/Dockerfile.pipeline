# Build from repo root, context = tax-ledger-analytics/data-platform:
#   docker build -f infra/docker/Dockerfile.pipeline -t doorrush-pipeline:latest data-platform
#
FROM python:3.12-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY src ./src
ENV PYTHONPATH=/app
CMD ["python", "-m", "src.pipeline"]
